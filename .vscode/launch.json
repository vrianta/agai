{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "build Mac",
      "type": "bash",
      "request": "launch",
      "mode": "auto",
      "program": "bash",
      "args": ["-c", "sudo bash ${fileDirname}/install_mac.sh"],
      "showLog": true
    },
    {
      "name": "build Linux",
      "type": "bash",
      "request": "launch",
      "mode": "auto",
      "program": "bash",
      "args": ["-c", "sudo bash ${fileDirname}/install_linux.sh"],
      "showLog": true
    },
    {
      "name": "build Windows",
      "type": "PowerShell",
      "request": "launch",
      "program": "${fileDirname}/install_windows.ps1",
      "showLog": true
    },
  ]
}
