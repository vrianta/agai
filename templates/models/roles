package models

import (
	"github.com/vrianta/agai/v1/model"
)

var Roles = model.New("roles", struct {
	RolesId *model.Field
	Name    *model.Field
}{
	RolesId: &model.Field{
		Nullable: false,
		Type:     model.FieldTypes.Int,
		Length:   10,
		Index: model.Index{
			PrimaryKey: true,
			Index:      true,
		},
	},
	Name: &model.Field{
		Type:   model.FieldTypes.String,
		Length: 20,
		Index: model.Index{
			Index:  true,
			Unique: true,
		},
	},
})
