package models

import (
	_ "github.com/go-sql-driver/mysql"
	"github.com/vrianta/agai/v1/model"
)

var Users = model.New("users", struct {
	Id       *model.Field
	Name     *model.Field
	Password *model.Field
}{
	Id: &model.Field{
		Nullable: false,
		Type:     model.FieldTypes.Int,
		Length:   10,
		Index: model.Index{
			PrimaryKey: true,
		},
	},
	Name: &model.Field{
		Nullable: false,
		Type:     model.FieldTypes.String,
		Length:   100,
	},
	Password: &model.Field{
		Nullable: false,
		Type:     model.FieldTypes.String,
		Length:   255,
	},
})
