package models

import (
	_ "github.com/go-sql-driver/mysql"
	"github.com/vrianta/agai/v1/model"
)

var UserDetails = model.New("user_details", struct {
	Id           *model.Field
	Phone        *model.Field
	Email        *model.Field
	FirstName    *model.Field
	LastName     *model.Field
	PrimarySkill *model.Field
	Experience   *model.Field
	Address      *model.Field
}{
	Id: Users.Fields.Id.ToForeignKey("cascade", "cascade", true, false, false),
	Phone: &model.Field{
		Nullable: false,
		Type:     model.FieldTypes.String,
		Length:   20,
		Index: model.Index{
			Unique: true,
			Index:  true,
		},
	},
	Email: &model.Field{
		Nullable: true,
		Type:     model.FieldTypes.String,
		Length:   150,
		Index: model.Index{
			Unique: true,
		},
	},
	FirstName: &model.Field{
		Type:   model.FieldTypes.String,
		Length: 100,
	},
	LastName: &model.Field{
		Nullable: true,
		Type:     model.FieldTypes.String,
		Length:   100,
	},
	PrimarySkill: &model.Field{
		Type:   model.FieldTypes.String,
		Length: 15,
	},
	Experience: &model.Field{
		Type:   model.FieldTypes.String,
		Length: 15,
	},
	Address: &model.Field{
		Nullable: true,
		Type:     model.FieldTypes.Text,
	},
})
